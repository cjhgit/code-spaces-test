// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/markdown
{
	"name": "Code Spaces Test",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"build": {
		"dockerfile": "Dockerfile"
	},
	"workspaceFolder": "/workspaces/code-spaces-test",

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Configure tool-specific properties.
	"customizations": {
		// Configure properties specific to VS Code.
		"vscode": {			
			// Add the IDs of extensions you want installed when the container is created.
			"extensions": [
				
			]
		}
	},
	"features": {
		"ghcr.io/devcontainer-config/features/dot-config:4": {}
	},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	"forwardPorts": [3000, 3172],
	"portsAttributes": {
		"3000": {
			"label": "Application",
			"onAutoForward": "notify"
		},
		"3172": {
			"label": "Dev Server",
			"onAutoForward": "notify"
		}
	},
	
	// Docker run arguments to map ports
	"runArgs": ["-p", "3000:3000", "-p", "3172:3172", "-w", "/workspaces/code-spaces-test"],

	// Mount .claude/settings.json and .ssh (readonly) from host to container
	"mounts": [
		"source=${localEnv:HOME}/.claude/settings.json,target=/root/.claude/settings.json,type=bind",
		"source=${localEnv:HOME}/.ssh,target=/tmp/host-ssh,type=bind,readonly"
	],

	// Use 'postCreateCommand' to run commands after the container is created.
	"postCreateCommand": "bash -c 'grep -q \"cd /workspaces/code-spaces-test\" ~/.bashrc || echo \"cd /workspaces/code-spaces-test\" >> ~/.bashrc; mkdir -p /root/.ssh && chmod 700 /root/.ssh && cp -r /tmp/host-ssh/id_* /tmp/host-ssh/known_hosts /root/.ssh/ 2>/dev/null || true && chmod 600 /root/.ssh/id_* 2>/dev/null || true && cat > /root/.ssh/config << \"EOF\"\nHost *\n    StrictHostKeyChecking accept-new\n    IdentitiesOnly no\nEOF\n'",

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
